generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String            @id @default(cuid())
  username                   String            @unique
  name                       String
  email                      String            @unique
  password                   String
  role                       Role              @default(CLIENT)
  status                     Status            @default(ACTIVE)
  approvedBy                 String?
  lastLogin                  DateTime          @default(now())
  isVerified                 Boolean           @default(false)
  resetPasswordToken         String?
  resetPasswordExpiresAt     DateTime?
  verificationToken          String?
  verificationTokenExpiresAt DateTime?
  notificationsEnabled       Boolean           @default(true)
  passwordStrength           PasswordStrength?
  passwordUpdateDeadline     DateTime?
  hasUpdatedWeakPassword     Boolean           @default(false)
  rememberToken            String?
  rememberTokenExpiresAt  DateTime?
  isOnline                   Boolean           @default(false)
  lastActivity               DateTime?
  onlineAt                   DateTime?
  profilePhoto               String?
  planTier                   PlanTier          @default(BASIC)
  aiReplyCount               Int              @default(0)
  aiReplyResetAt              DateTime          @default(now())
  timezone                   String?           @default("UTC")
  workingHoursStart          String?           @default("09:00")
  workingHoursEnd            String?           @default("17:00")
  workingDays                String[]           @default(["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"])
  preferredContactTime       String?           @default("business-hours")
  autoResponseEnabled        Boolean           @default(true)
  responseDelayMinutes       Int               @default(0)
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  
  // OAuth fields
  googleId                   String?           @unique
  githubId                   String?           @unique
  oauthProvider              String?
  emailVerifiedAt            DateTime?

  tickets         Ticket[]
  assignedTickets Ticket[]             @relation("AssignedTickets")
  comments        Comment[]
  replies         Reply[]
  notifications   Notification[]
  contactProfiles ContactUserProfile[]
  personalNotes   PersonalNote[]
}

model Ticket {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedToId      String?
  assignedTo        User?            @relation("AssignedTickets", fields: [assignedToId], references: [id])
  location          String
  issueType         IssueType
  subject           String
  description       String
  urgency           Urgency          @default(LOW)
  status            TicketStatus     @default(OPEN)
  visibility        Visibility       @default(ROLE_BASED)
  isAutomated       Boolean          @default(false)
  autoResolvedAt    DateTime?
  automationHistory Json?
  resolutionMethod  ResolutionMethod @default(MANUAL)
  feedbackSubmitted Boolean          @default(false)
  chatEnabled       Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  comments      Comment[]
  notifications Notification[]
  attachments   Attachment[]
}

model Comment {
  id                 String   @id @default(cuid())
  ticketId           String
  ticket             Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  content            String
  isHidden           Boolean  @default(false)
  unhideCode         String?
  approvedForManager Boolean  @default(false)
  isOffensive        Boolean  @default(false)
  commentCount       Int      @default(0)
  replies            Reply[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Reply {
  id          String    @id @default(cuid())
  commentId   String
  comment     Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  aiGenerated Boolean   @default(false)
  editedById  String?
  editedAt    DateTime?
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  ticketId       String
  ticket         Ticket           @relation(fields: [ticketId], references: [id])
  type           NotificationType
  title          String
  message        String
  previousStatus TicketStatus?
  newStatus      TicketStatus?
  read           Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model PersonalNote {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketId    String
  content     String
  sharedWith  String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([ticketId])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New Chat")
  messages  ChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String       @id @default(cuid())
  sessionId String
  session   ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String
  images    Json?        // Array of { base64, filename, mimeType, size }
  timestamp DateTime     @default(now())
}

enum MessageRole {
  USER
  ASSISTANT
}

model ContactUs {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactUserProfile {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  address         String   @default("")
  country         String   @default("")
  county          String   @default("")
  telephoneNumber String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Attachment {
  id           String   @id @default(cuid())
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  filename     String
  originalName String?
  mimetype     String?
  size         Int
  url          String?
  uploadedAt   DateTime @default(now())
  uploadedById String?
}

enum Role {
  CLIENT
  MANAGER
  REVIEWER
}

enum Status {
  ACTIVE
  REJECTED
  PENDING
}

enum PasswordStrength {
  weak
  medium
  strong
}

enum PlanTier {
  BASIC
  PRO
  ENTERPRISE
}

enum IssueType {
  HARDWARE_ISSUE
  SOFTWARE_ISSUE
  NETWORK_CONNECTIVITY
  ACCOUNT_ACCESS
  OTHER
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Visibility {
  ROLE_BASED
}

enum ResolutionMethod {
  MANUAL
  AUTO
}

enum NotificationType {
  STATUS_UPDATE
  NEW_COMMENT
  TICKET_ASSIGNED
  TICKET_RESOLVED
  FEEDBACK_REQUESTED
  NOTE_SHARED
  NOTE_SHARED_OWNER
}
